<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{resume.basics.name}} - Resume</title>
    <style>{{{css}}}</style>
</head>
<body>
    <div class="resume-container">
        <header class="header">
            {{#if resume.basics.image}}
            <div class="photo-container">
                <img src="{{resume.basics.image}}" alt="{{resume.basics.name}}" class="profile-photo">
            </div>
            {{/if}}
            <div class="header-content">
                <h1>{{resume.basics.name}}</h1>
                <h2>{{{resume.basics.label}}}</h2>
            </div>

            <!-- Contact Information -->
            <div class="contact-info">
                {{#if resume.basics.email}}
                <span>{{resume.basics.email}}</span>
                {{/if}}
                {{#if resume.basics.phone}}
                <span class="separator">•</span>
                <span>{{resume.basics.phone}}</span>
                {{/if}}
                {{#if resume.basics.location}}
                <span class="separator">•</span>
                <span>{{resume.basics.location.city}}, {{resume.basics.location.countryCode}}</span>
                {{/if}}
                {{#each resume.basics.profiles}}
                <span class="separator">•</span>
                <span><a href="{{url}}" target="_blank">{{network}}</a></span>
                {{/each}}
            </div>
        </header>

        <!-- Professional Summary -->
        {{#if resume.basics.summary}}
        <section class="summary">
            <h3>Summary</h3>
            <p>{{{highlightSkills resume.basics.summary resume.skills}}}</p>
        </section>
        {{/if}}

        <!-- Work Experience -->
        {{#if resume.work}}
        <section class="experience">
            <h3>Experience</h3>
            {{#each resume.work}}
            {{#if (not _archived)}}
            <div class="experience-item">
                <div class="experience-header">
                    <div class="experience-title-company">
                        <span class="experience-title">{{position}}</span>
                        <span class="experience-company-separator"> | </span>
                        <span class="experience-company">{{#if url}}<a href="{{url}}" target="_blank">{{name}}</a>{{else}}{{name}}{{/if}}</span>
                        {{#if location}}
                        <span class="experience-location"> - {{location}}</span>
                        {{/if}}
                    </div>
                    <div class="experience-date">
                        {{#if startDate}}
                            {{monthName startDate}} {{year startDate}}
                            {{#if endDate}} - {{monthName endDate}} {{year endDate}}{{else}} - Present{{/if}}
                        {{/if}}
                    </div>
                </div>
                {{#if summary}}
                <div class="experience-summary">{{{highlightSkills summary ../resume.skills}}}</div>
                {{/if}}
                {{#if highlights}}
                <ul class="experience-highlights">
                    {{#each highlights}}
                    <li>{{{highlightSkills this ../../resume.skills}}}</li>
                    {{/each}}
                </ul>
                {{/if}}
            </div>
            {{/if}}
            {{/each}}
        </section>
        {{/if}}

        <!-- Education -->
        {{#if resume.education}}
        <section class="education">
            <h3>Education</h3>
            {{#each resume.education}}
            <div class="education-item">
                <div class="education-header">
                    <div class="education-degree-institution">
                        <span class="education-degree">{{studyType}} in {{area}}</span>
                        <span class="education-institution-separator"> | </span>
                        <span class="education-institution">{{#if url}}<a href="{{url}}" target="_blank">{{institution}}</a>{{else}}{{institution}}{{/if}}</span>
                    </div>
                    <div class="education-date">
                        {{#if startDate}}
                            {{monthName startDate}} {{year startDate}}
                            {{#if endDate}} - {{monthName endDate}} {{year endDate}}{{else}} - Present{{/if}}
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/each}}
        </section>
        {{/if}}

        <!-- Skills/Expertise -->
        {{#if resume.skills}}
        <section class="expertise">
            <h3>Skills</h3>
            <div class="skills-container">
            {{#each resume.skills}}
                <div class="skill-category">
                    <span class="expertise-name">{{name}}:</span>
                    <span class="expertise-keywords">
                        {{#each keywords}}
                        {{this}}{{#unless @last}}, {{/unless}}
                        {{/each}}
                    </span>
                </div>
            {{/each}}
            </div>
        </section>
        {{/if}}

        <!-- Languages -->
        {{#if resume.languages}}
        <section class="languages">
            <h3>Languages</h3>
            <div class="languages-container">
                {{#each resume.languages}}
                <span class="language-item">{{language}} ({{fluency}}){{#unless @last}}, {{/unless}}</span>
                {{/each}}
            </div>
        </section>
        {{/if}}
    </div>
</body>
</html>
